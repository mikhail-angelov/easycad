# Production environment for easycad.bconf.com.
# Copy to `.env.prod`, fill in the secrets, then `make install` ships it to the
# server as /opt/easycad/.env. Do NOT commit the filled-in .env.prod.

# ── Auth (SPEC13) ────────────────────────────────────────────────────────────
JWT_SECRET=                       # long random string — signs magic-link + session JWTs
APP_URL=https://easycad.bconf.com # base URL used in magic-link emails

# ── Email (magic link) — same Yandex postbox as playground ───────────────────
MAIL_FROM=no-reply@js2go.ru
POST_SERVICE_URL=postbox.cloud.yandex.net
POST_USER=
POST_PASS=

# ── Free trial + BYOK (SPEC14) ───────────────────────────────────────────────
# New visitors get free generations on the operator's DeepSeek key before they
# add their own, so DEEP_SEEK_KEY is REQUIRED for the trial to work (not just a
# dev fallback). After the grant, users bring their own key (BYOK).
DEEP_SEEK_KEY=                     # operator key that powers the free trial
EASYCAD_TRIAL_ANON=1              # free generations for an anonymous visitor (by IP)
EASYCAD_TRIAL_USER=10             # free generations for a signed-in account
# EASYCAD_ANON_TRIAL_TTL=2592000  # prune anon IP rows older than N seconds (default 30d)
# Set both TRIAL_* to 0 to disable the trial (then users must add their own key).
# OPEN_ROUTER_KEY=                 # optional — only a local/dev BYOK env fallback

# ── Sessions & storage ───────────────────────────────────────────────────────
EASYCAD_DB_PATH=/data/easycad.db  # accounts + settings (durable)
EASYCAD_SESSION_TTL=7200          # idle session eviction, seconds
EASYCAD_MAX_SESSIONS=500
EASYCAD_SECURE_COOKIES=1          # cookies only over HTTPS (redoproxy terminates TLS)

# ── Execution worker (SPEC12) ────────────────────────────────────────────────
EASYCAD_WORKER_URL=http://worker:8853
CADQUERY_WORKER_TIMEOUT_SECONDS=120
