# Production environment for easycad.bconf.com.
# Copy to `.env.prod`, fill in the secrets, then `make install` ships it to the
# server as /opt/easycad/.env. Do NOT commit the filled-in .env.prod.

# ── LLM providers (at least DeepSeek) ────────────────────────────────────────
DEEP_SEEK_KEY=
OPEN_ROUTER_KEY=
OPEN_ROUTER_MODEL=
OPEN_ROUTER_PLANNER_MODEL=

# ── runtime ──────────────────────────────────────────────────────────────────
# Delegate CadQuery execution to the isolated worker container (set in compose,
# repeated here for clarity — compose `environment:` wins if both are present).
EASYCAD_WORKER_URL=http://worker:8853
EASYCAD_SESSION_FILE=/data/session.json
CADQUERY_WORKER_TIMEOUT_SECONDS=120
