    "language": "cadquery-python",
    "source": "# Parameters\nbase_length = PARAMETERS['base_length']\nbase_width = PARAMETERS['base_width']\nbase_height = PARAMETERS['base_height']\nriser_height = PARAMETERS['riser_height']\nriser_width = PARAMETERS['riser_width']\nfront_slot_width = PARAMETERS['front_slot_width']\nfront_slot_depth = PARAMETERS['front_slot_depth']\ntop_slot_width = PARAMETERS['top_slot_width']\ntop_slot_depth = PARAMETERS['top_slot_depth']\n\n# Base plate\nbase_plate = cq.Workplane(\"XY\").box(base_length, base_width, base_height)\n\n# Top riser (centered on base along length, flush with back? Assume centered)\n# Place riser on top of base, centered along length and width? \n# Actually, typical: riser sits on base, centered along length, flush with back? \n# Assume centered along length and width for simplicity.\nriser = cq.Workplane(\"XY\").workplane(offset=base_height).box(base_length, riser_width, riser_height)\n# Center riser on base\nriser = riser.translate((0, (base_width - riser_width)/2, 0))\ntop_riser = base_plate.union(riser)\n\n# Front slot: cut on front face (Y positive direction? Assume front is Y+)\n# Slot centered on front face, width along X, depth along Y\nfront_slot = cq.Workplane(\"XY\").workplane(offset=base_height/2).box(front_slot_width, front_slot_depth, base_height)\nfront_slot = front_slot.translate((0, base_width/2, 0))\nresult = top_riser.cut(front_slot)\n\n# Top U-slot: longitudinal slot on top of riser, centered, full length\n# Slot width along X, depth along Z, length along Y? Actually length along X (since riser length is along X)\n# Assume slot runs full length of riser (base_length) along X, centered on top face\n# Create slot as a box and cut\nslot = cq.Workplane(\"XY\").workplane(offset=base_height + riser_height).box(base_length, top_slot_width, top_slot_depth)\nslot = slot.translate((0, (base_width - riser_width)/2 + riser_width/2, -top_slot_depth/2))\nresult = result.cut(slot)\n\n# Final result\nresult = result"
  },
