  "cad": {
    "entry_variable": "result",
    "generation_attempt": 1,
    "language": "cadquery-python",
    "source": "p = PARAMETERS\n\nbase = cq.Workplane(\"XY\").box(p[\"overall_length\"], p[\"overall_width\"], p[\"base_height\"], centered=False)\n\nupright = (\n    cq.Workplane(\"XY\")\n    .box(p[\"upright_thickness\"], p[\"overall_width\"], p[\"overall_height\"] - p[\"base_height\"], centered=False)\n    .translate((p[\"overall_length\"] - p[\"upright_thickness\"], 0, p[\"base_height\"]))\n)\n\nbody = base.union(upright)\n\nmain_hole = (\n    cq.Workplane(\"XY\")\n    .circle(p[\"hole_diameter\"] / 2)\n    .extrude(p[\"base_height\"] + 2)\n    .translate((p[\"hole_center_from_left\"], p[\"overall_width\"] / 2, -1))\n)\n\nwith_main_hole = body.cut(main_hole)\n\nfront_notch = (\n    cq.Workplane(\"XY\")\n    .circle(p[\"end_notch_radius\"])\n    .extrude(p[\"base_height\"] + 2)\n    .translate((0, p[\"overall_width\"] / 2, -1))\n)\n\nwith_notch = with_main_hole.cut(front_notch)\n\ntop_slot = (\n    cq.Workplane(\"XY\")\n    .box(p[\"upright_thickness\"], p[\"top_slot_width\"], p[\"top_slot_depth\"], centered=False)\n    .translate((p[\"overall_length\"] - p[\"upright_thickness\"], (p[\"overall_width\"] - p[\"top_slot_width\"]) / 2, p[\"overall_height\"] - p[\"top_slot_depth\"]))\n)\n\nresult = with_notch.cut(top_slot)\n"
  },
